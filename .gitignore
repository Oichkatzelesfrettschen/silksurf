# silksurf .gitignore -- one entry per line, alphabetised within sections.
# See docs/REPO-LAYOUT.md for the full directory inventory.

## Build trees -----------------------------------------------------------
/build/
/build-*/
build-fuzz/
/target
/**/target/
*.a
*.dll
*.dylib
*.exe
*.o
*.so

## Coverage / profiling --------------------------------------------------
*.profraw
/perf/results/

## Crash dumps -----------------------------------------------------------
*.data
core
/core
/core.*
/logs/
/logs/cores/

## Databases (test/profiling artifacts) ---------------------------------
*.db
*.db-shm
*.db-wal

## Fuzzing outputs -------------------------------------------------------
/fuzz/artifacts/
/fuzz/corpus/
/fuzz_in/
/fuzz_in_css/
/fuzz_out/
/fuzz_out_css/

## Static analysis -------------------------------------------------------
/infer-out/

## Tool / IDE / per-user state ------------------------------------------
/.claude/settings.local.json
/silksurf-extras/
/silksurf-js/test262/

## Accidental artifacts --------------------------------------------------
# `~/` is created by tools that write to "$HOME" without expanding the tilde.
/~/

## TLA+ scratch ----------------------------------------------------------
# TLC writes state-graph artefacts here; the .tla model itself is tracked.
/states/
