# EditorConfig: https://editorconfig.org
# Single source of truth for whitespace conventions across editors and IDEs.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{rs,toml}]
indent_style = space
indent_size = 4
max_line_length = 100

[*.{md,markdown}]
trim_trailing_whitespace = false
max_line_length = off

[*.{yml,yaml,json}]
indent_size = 2

[*.{c,cc,cpp,cxx,h,hh,hpp,hxx}]
indent_size = 4

[Makefile]
indent_style = tab

[*.py]
indent_size = 4

[*.{sh,bash}]
indent_size = 4
